generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model OkrItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identity
  code      String?
  title     String
  type      String
  sortOrder Int     @default(0)

  // Execution fields (File 1, all editable)
  project     String?
  status      String    @default("Chưa bắt đầu")
  startDate   DateTime?
  endDate     DateTime?
  owner       String?
  stakeholder String?
  chotFlag    String?
  isOptional  Boolean   @default(false)
  completedAt DateTime?

  // Strategic fields (File 2, read-only in UI)
  strategicPillar    String?
  deadline           String?
  pic                String?
  scope              String?
  description        String?
  successMetric      String?
  targetValue        String?
  measureFormula     String?
  corporateKRLinkage String?
  notes              String?

  // Computed
  progressPct Float @default(0)

  // Self-referencing hierarchy
  parentId String?
  parent   OkrItem?  @relation("ItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children OkrItem[] @relation("ItemTree")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  // What item was affected
  itemId     String
  itemTitle  String
  itemType   String
  itemCode   String?

  // What happened
  action     String   // 'CREATED' | 'UPDATED' | 'DELETED'
  field      String?  // null for CREATED/DELETED; field name for UPDATED
  oldValue   String?
  newValue   String?
}

// ─── Kế hoạch hành động (Monthly Action Plan) ────────────────────────────────

model ActionPlan {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  month     Int
  year      Int
  title     String
  notes     String?
  closedAt  DateTime?

  goals     MonthlyGoal[]
  kpis      KpiItem[]
}

model MonthlyGoal {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  planId         String
  plan           ActionPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  sortOrder      Int      @default(0)
  title          String
  okrLinkage     String?
  expectedResult String?

  actionItems    ActionItem[]

  @@index([planId])
}

model ActionItem {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  goalId         String
  goal           MonthlyGoal  @relation(fields: [goalId], references: [id], onDelete: Cascade)

  sortOrder      Int      @default(0)
  task           String
  expectedResult String?
  pic            String?
  startDate      DateTime?
  endDate        DateTime?
  status         String   @default("Chưa triển khai")
  budget         String?
  okrLinkage     String?

  @@index([goalId])
}

model KpiItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planId    String
  plan      ActionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  sortOrder Int      @default(0)
  metric    String
  target    String?
  actual    String?
  note      String?

  @@index([planId])
}
